		"eslint-plugin-svelte": "^3.16.0",
		"formsnap": "^2.0.1",
		"globals": "^17.4.0",
		"mode-watcher": "^1.1.0",
		"postcss": "^8.5.8",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"prettier-plugin-tailwindcss": "^0.7.2",
		"prisma": "^7.5.0",
		"shadcn-svelte": "^1.2.2",
		"svelte": "^5.54.1",
		"svelte-check": "^4.4.5",
		"svelte-sonner": "^1.1.0",
		"sveltekit-superforms": "^2.30.0",
